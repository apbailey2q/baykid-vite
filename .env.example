# ─────────────────────────────────────────────────────────────────────────────
# BayKid — canonical .env reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local development and fill the values in.
# For staging + production deploys, set the same variables in Vercel:
#   Project → Settings → Environment Variables (scope = Preview or Production).
#
# Anything labeled SECRET goes in Vercel ONLY (or Supabase secrets for the
# Edge Function ones). NEVER commit real values to git — `.env*` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────


# ── App identity ─────────────────────────────────────────────────────────────
# Drives lib/env.ts → ENV, the QA-checklist environment column, and the
# /api/health payload's `environment` field.

VITE_ENVIRONMENT=local                              # local | staging | production
VITE_APP_VERSION=dev                                # auto-injected as ${VERCEL_GIT_COMMIT_SHA} in CI


# ── Supabase (required) ─────────────────────────────────────────────────────
# Get these from Supabase: Project → Settings → API.
# Each environment should point at a DIFFERENT Supabase project:
#   local   → shared dev project
#   staging → staging project (separate from prod)
#   prod    → production project

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...                   # anon public key, safe to ship


# ── Anthropic / Claude (required for AI Marketing) ──────────────────────────
# The Vercel API routes in api/ai/* read this. NOT prefixed with VITE_ —
# it's server-side only, never reaches the browser bundle.

ANTHROPIC_API_KEY=sk-ant-...                        # SECRET — set in Vercel only
ANTHROPIC_MODEL=claude-sonnet-4-6                   # use current non-retired model
APP_URL=https://your-production-domain.com           # required for CORS allowlist in api/ai/*


# ── Stripe (required for billing) ────────────────────────────────────────────
# Publishable key is safe in the browser bundle (VITE_ prefix).
# Secret + webhook keys live in Supabase Edge Function secrets, NOT in Vercel.
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#   supabase secrets set STRIPE_BILLING_WEBHOOK_SECRET=whsec_...

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...             # pk_test_ for staging, pk_live_ for prod


# ── Error + analytics (recommended) ──────────────────────────────────────────
# Both are loaded via dynamic import in lib/monitoring.ts — leave blank to
# disable; the app falls back to console logging only.

VITE_SENTRY_DSN=                                    # https://xxx@sentry.io/yyy
VITE_POSTHOG_KEY=                                   # phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com           # optional, defaults to app.posthog.com


# ── Support routing ──────────────────────────────────────────────────────────
# Where the marketing site's "Email us" link points + the in-app
# "for urgent issues email…" copy.

VITE_SUPPORT_EMAIL=support@baykid.ai


# ── Local-dev knobs (DO NOT set true in production) ──────────────────────────
# Show demo-role buttons on /real-login so test users can role-switch fast.
# Production environment MUST have this as false (or unset).

VITE_ENABLE_DEMO_ACCESS=true                        # true in local/staging, false in prod
VITE_SEED_MOCK_DATA=false                           # true only in local dev to pre-fill sample posts/leads/calendar


# ── Legacy / app-specific ────────────────────────────────────────────────────
# Pre-existing variables from the recycling app. Keep documented so they
# don't get dropped by accident on a config refresh.

VITE_DEV_BYPASS_AUTH=false                          # force-real auth even in dev
