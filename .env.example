# Required — get these from your Supabase project dashboard (Settings → API)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Set to "false" in .env.local to force real auth even in dev mode.
# In production builds this is always false regardless of this value.
VITE_DEV_BYPASS_AUTH=false

# App Store download URLs (AP.3B — apartment resident enrollment funnel).
# Leave unset or empty to show "Coming Soon" buttons without breaking the flow.
VITE_APPLE_APP_STORE_URL=
VITE_GOOGLE_PLAY_URL=
