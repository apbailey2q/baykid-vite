# BayKid AI Marketing — LOCAL dev environment template
# Copy to `.env.local` and fill in. Never commit `.env.local` itself.

# ── Required: Supabase (local or shared dev project) ─────────────────────────
VITE_SUPABASE_URL=https://<your-dev-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── Required: app identity ───────────────────────────────────────────────────
VITE_ENVIRONMENT=local                 # local | staging | production
VITE_APP_VERSION=dev

# ── Optional: Stripe (UI runs in mock mode if blank) ─────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Optional: error + analytics integrations ─────────────────────────────────
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Optional: contact + support ──────────────────────────────────────────────
VITE_SUPPORT_EMAIL=support@baykid.local

# ── Optional: dev-only ───────────────────────────────────────────────────────
VITE_ENABLE_DEMO_ACCESS=true           # show demo-role buttons on /real-login
