# .env.production — Production environment template
# ⚠️  DO NOT store real values here. This file is documentation only.
# Set ALL production secrets in Vercel Dashboard → Settings → Environment Variables → Production
#
# Required checklist before first production deploy:
#   [ ] ANTHROPIC_API_KEY          → Vercel dashboard, Production env, no VITE_ prefix
#   [ ] ANTHROPIC_MODEL            → Vercel dashboard, Production env (claude-sonnet-4-6)
#   [ ] APP_URL                    → Vercel dashboard, server-side CORS allowlist (no VITE_ prefix)
#   [ ] VITE_APP_URL               → Vercel dashboard, browser-side (same domain as APP_URL)
#   [ ] VITE_SUPABASE_URL          → Production Supabase project URL
#   [ ] VITE_SUPABASE_ANON_KEY     → Production anon key (safe to be public, RLS enforces access)
#   [ ] VITE_STRIPE_PUBLISHABLE_KEY → Live key (pk_live_...)
#   [ ] VITE_SENTRY_DSN            → Sentry project DSN for error tracking
#   [ ] VITE_POSTHOG_KEY           → PostHog project API key for analytics
#   [ ] VITE_SEED_MOCK_DATA        → Must be false (or unset) in production
#   [ ] VITE_ENABLE_DEMO_ACCESS    → Must be false in production

# ── AI (server-side ONLY — no VITE_ prefix) ──────────────────────────────────
ANTHROPIC_API_KEY=          # REQUIRED — set in Vercel dashboard only, never here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=     # Production anon key (publishable, RLS-protected)

# ── CORS (both required for AI API to accept browser requests) ────────────────
APP_URL=https://your-production-domain.com        # server-side, no VITE_ prefix
VITE_APP_URL=https://your-production-domain.com   # browser-side

# ── Feature flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_DEMO_ACCESS=false
VITE_SEED_MOCK_DATA=false
VITE_ENVIRONMENT=production

# ── Monitoring ────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
VITE_POSTHOG_KEY=phc_your-production-posthog-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Stripe (LIVE keys for production) ────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-live-stripe-key

# ── App metadata (Vercel auto-injects $VERCEL_GIT_COMMIT_SHA) ────────────────
VITE_APP_VERSION=$VERCEL_GIT_COMMIT_SHA

# ── Push notifications (optional) ────────────────────────────────────────────
# VITE_VAPID_PUBLIC_KEY=     # Leave unset to disable push; beta notice shown to users

# ── Google APIs (optional — bag inspection) ───────────────────────────────────
# GOOGLE_VISION_API_KEY=     # Vercel dashboard only (no VITE_ prefix)
#                            # Same key also needed as Supabase secret for Edge Functions:
#                            #   supabase secrets set GOOGLE_VISION_API_KEY=<key>
#                            # Key must have both Cloud Vision API and Generative Language API enabled
