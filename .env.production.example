# ============================================================
# BayKid Production Environment Variables
# Cyan's Brooklynn Recycling Enterprise
# ============================================================
# Copy this file to .env.production.local (gitignored).
# Set all of these in your Vercel project dashboard under
# Settings → Environment Variables → Production.
#
# CRITICAL: Never commit real values to git.
# CRITICAL: Never expose service role keys or Stripe secret keys here.
# ============================================================

# ── Supabase (production project only) ───────────────────────────────────────
# Use the PRODUCTION Supabase project — not development.
# Anon key only. Never put service_role key in frontend builds.
VITE_SUPABASE_URL=https://YOUR_PROD_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon_key_only...

# ── App mode — all flags must be OFF in production ───────────────────────────
# Do NOT set VITE_DEV_BYPASS_AUTH in production.
# Do NOT set VITE_DEMO_MODE in production.
VITE_ENABLE_DEMO_ACCESS=false

# ── Stripe (frontend — publishable key only) ─────────────────────────────────
# Switch from pk_test_ to pk_live_ for production.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Optional monitoring (add after launch) ───────────────────────────────────
# Sentry DSN for error monitoring (src/lib/monitoring.ts)
# VITE_SENTRY_DSN=https://...@sentry.io/...

# PostHog key for analytics (optional)
# VITE_POSTHOG_KEY=phc_...

# ============================================================
# Backend secrets — set ONLY in Supabase Edge Function secrets
# (Supabase Dashboard → Settings → Edge Functions → Secrets)
# NEVER put these in frontend env vars.
# ============================================================
#
# SUPABASE_SERVICE_ROLE_KEY   — used by Edge Functions for privileged DB ops
# STRIPE_SECRET_KEY           — sk_live_... — Stripe charges and payouts
# STRIPE_WEBHOOK_SECRET       — whsec_... — webhook signature verification
# EXPO_ACCESS_TOKEN           — for Expo push notification delivery
# OSRM_API_KEY                — if using a paid OSRM provider (currently free)
#
# ============================================================
# Supabase Dashboard settings to confirm before launch
# ============================================================
#
# Database:
#   Settings → Database → Backups → Enable daily backups
#   Settings → Database → Backups → Enable point-in-time recovery (paid plan)
#
# Auth:
#   Authentication → URL Configuration → Site URL = https://yourdomain.com
#   Authentication → URL Configuration → Redirect URLs = https://yourdomain.com/**
#
# API:
#   Settings → API → JWT Expiry = 3600 (1 hour)
#   Settings → API → Allowed Origins = https://yourdomain.com (remove localhost)
#
# Storage:
#   Storage → Buckets → inspection-photos → Private, authenticated access only
#   Storage → Buckets → beta-screenshots  → Private, authenticated access only
#
# Realtime:
#   Realtime enabled for: commercial_route_stops, expected_warehouse_loads, profiles
