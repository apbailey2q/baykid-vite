# .env.staging — Staging environment template
# Set these in Vercel Dashboard → Settings → Environment Variables → Preview
# DO NOT commit real values. This file is documentation only.
#
# Staging should use:
#   - A SEPARATE Supabase project (not production)
#   - A separate Anthropic API key (or same key with quota monitoring)
#   - Test Stripe keys (pk_test_...)
#   - Real Sentry DSN (tag environment=staging)

# ── AI (server-side only — no VITE_ prefix, set in Vercel dashboard) ─────────
ANTHROPIC_API_KEY=          # Vercel dashboard: Preview env var
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Supabase (staging project) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-STAGING-project.supabase.co
VITE_SUPABASE_ANON_KEY=     # Staging anon key from Supabase dashboard

# ── CORS (both required for AI API to accept browser requests) ────────────────
APP_URL=https://baykid-vite-staging.vercel.app   # server-side, no VITE_ prefix
VITE_APP_URL=https://baykid-vite-staging.vercel.app

# ── Feature flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_DEMO_ACCESS=false
VITE_SEED_MOCK_DATA=false
VITE_ENVIRONMENT=staging

# ── Monitoring ────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
VITE_POSTHOG_KEY=phc_your-posthog-project-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Stripe (test keys for staging) ───────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-test-key

# ── App metadata ─────────────────────────────────────────────────────────────
VITE_APP_VERSION=$VERCEL_GIT_COMMIT_SHA

# ── Push notifications (optional) ────────────────────────────────────────────
# VITE_VAPID_PUBLIC_KEY=     # Leave unset to disable push; beta notice shown to users

# ── Google APIs (optional — bag inspection) ───────────────────────────────────
# GOOGLE_VISION_API_KEY=     # Vercel dashboard only (no VITE_ prefix)
#                            # Same key also needed as Supabase secret:
#                            #   supabase secrets set GOOGLE_VISION_API_KEY=<key>
