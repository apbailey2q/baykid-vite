# BayKid AI Marketing — STAGING environment template (Vercel)
# These values go in Vercel: Project → Settings → Environment Variables,
# scope = "Preview" (or a "staging" environment if configured).

# ── Required: Supabase (separate staging project) ────────────────────────────
VITE_SUPABASE_URL=https://<staging-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>

# ── Required: app identity ───────────────────────────────────────────────────
VITE_ENVIRONMENT=staging
VITE_APP_VERSION=${VERCEL_GIT_COMMIT_SHA}    # Vercel auto-injects this

# ── Stripe (USE TEST KEYS in staging — never live keys) ──────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<staging-test-key>
# Secret keys go in Edge Function secrets via `supabase secrets set`,
# NOT in Vercel env vars.

# ── Error + analytics (staging projects, not production) ─────────────────────
VITE_SENTRY_DSN=https://<staging-dsn>@sentry.io/<staging-project-id>
VITE_POSTHOG_KEY=phc_<staging-key>
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Support routing ──────────────────────────────────────────────────────────
VITE_SUPPORT_EMAIL=beta@baykid.example

# ── Staging-only knobs ───────────────────────────────────────────────────────
VITE_ENABLE_DEMO_ACCESS=true          # OK in staging, never in production
